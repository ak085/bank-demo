"""
FastAPI router for {{ identity.display_name_en }} ({{ identity.kind }}).

The demo guard pattern is mandatory: every read endpoint short-circuits
to the demo provider when DATA_MODE=demo. Live code must remain untouched
by demo logic.
"""

from fastapi import APIRouter, Depends, Request

from app.auth import get_current_user, require_role
from app.config import settings
from app.providers import demo_{{ identity.kind }} as demo

router = APIRouter(prefix="/api/{{ identity.kind }}", tags=["{{ identity.kind }}"])


@router.get("")
async def list_equipment(request: Request):
    if settings.data_mode == "demo":
        return demo.get_equipment_list()
    get_current_user(request)
    # ── live code below ──
    raise NotImplementedError("Live implementation lives outside the demo skill.")


@router.get("/{instance_id}/setpoints")
async def get_setpoints(instance_id: str, request: Request):
    if settings.data_mode == "demo":
        return demo.get_setpoints(instance_id)
    get_current_user(request)
    raise NotImplementedError


@router.post("/{instance_id}/setpoints/{suffix}")
async def write_setpoint(
    instance_id: str,
    suffix: str,
    body: dict,
    _=Depends(require_role("admin", "operator")),
):
    """Setpoint write — role-gated even in demo mode."""
    if settings.data_mode == "demo":
        # demo provider validates suffix against ARCHETYPE['setpoints']
        return demo.write_setpoint(instance_id, suffix, body["value"])
    raise NotImplementedError
