/**
 * Equipment detail page for {{ identity.display_name_en }} — /{{ identity.kind }}/[id]
 *
 * Page contract (AIHVAC_DASHBOARD_FRAMEWORK.md §3.5):
 *   Show the operational state of one physical equipment item and provide
 *   write access to authorised operators.
 *
 * Forbidden on this page:
 *   - Points from other equipment
 *   - Historical trend charts (link to /monitor/trends?equipment=[id])
 *   - Scheduling controls (belong on /operate/schedules)
 *
 * All styling: Tailwind + shadcn/ui only. All charts: ECharts via <EChart>.
 * Zero inline style={}, zero hardcoded hex colors, zero new libraries.
 */

"use client"

import { useEffect, useMemo, useState } from "react"
import { useParams } from "next/navigation"
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card"
import { Badge } from "@/components/ui/badge"
import { useLang } from "@/components/LangProvider"
import { EChart } from "@/components/charts/EChart"

type Point = {
  pointId: number
  value: number | null
  units: string
  dis: string
  quality: string
  lastSeen: string
}

type InstancePayload = {
  name: string
  status: "online" | "offline"
  points: Record<string, Point>
}

export default function {{ pascal_case identity.kind }}DetailPage() {
  const { t } = useLang()
  const { id } = useParams<{ id: string }>()
  const [data, setData] = useState<InstancePayload | null>(null)

  useEffect(() => {
    let cancelled = false
    async function load() {
      const res = await fetch(`/api/{{ identity.kind }}/${id}`)
      if (!cancelled) setData(await res.json())
    }
    load()
    const t = setInterval(load, 5000)
    return () => { cancelled = true; clearInterval(t) }
  }, [id])

  // Header band — name, status, last comms (5-second-rule answers (a) and (b))
  // Gauges from pages.equipment_detail.primary_gauges in the archetype YAML
  // Operating params table — every point in the archetype, read-only
  // Override panel — only points listed in setpoints[], role-gated client-side
  //   AND server-side (require_role on the API endpoint)

  // TODO Phase 2: generator stamps the exact gauge list and operating-param
  // rows from archetype.pages.equipment_detail and archetype.points[].pages.
  return (
    <div className="flex flex-col gap-4 p-4">
      <header className="flex items-center justify-between">
        <h1 className="text-xl font-semibold">
          {data?.name ?? t("common.loading")}
        </h1>
        <Badge variant={data?.status === "online" ? "default" : "destructive"}>
          {t(`common.${data?.status ?? "loading"}`)}
        </Badge>
      </header>

      {/* primary gauges (ECharts) — listed in archetype.pages.equipment_detail.primary_gauges */}
      <section className="grid grid-cols-2 gap-3 md:grid-cols-4">
        {/* GenerateOnePerGauge(archetype.pages.equipment_detail.primary_gauges) */}
      </section>

      {/* operating parameters table — every point this archetype declares */}
      <Card>
        <CardHeader className="pb-2 pt-3 px-3">
          <CardTitle>{t("equipmentDetail.operatingParameters")}</CardTitle>
        </CardHeader>
        <CardContent className="p-3">
          {/* rows: one per archetype.points[] with pages including equipment_detail */}
        </CardContent>
      </Card>

      {/* override panel — only points in archetype.setpoints[], operator+ */}
      {/* must use AlertDialog confirmation and a "Release to Auto" button */}
    </div>
  )
}
