# ───────────────────────────────────────────────────────────────────
# i18n merge plan for {{ identity.display_name_en }} ({{ identity.kind }})
# ───────────────────────────────────────────────────────────────────
# Phase 2 will generate this file from <kind>.archetype.yaml `i18n:` block
# and deep-merge it into ~/contracts/i18n/defaults/{en,zh}.yaml.
#
# Rules the generator must enforce:
#   1. Existing keys win — never overwrite a contracts/i18n key. If the
#      archetype YAML defines a key that already exists in the contracts
#      dictionary with a different value, surface a conflict instead of
#      silently overwriting.
#   2. EN/ZH parity — the generator fails if the archetype's en and zh
#      key sets differ.
#   3. Site override layer untouched — the generator never writes under
#      ~/contracts/i18n/sites/. Customer-specific renames stay there.
# ───────────────────────────────────────────────────────────────────

en:
  # Pulled verbatim from archetype.i18n.en at generation time.
  # Sections present: points, kpis, alarms (and any others the archetype declares).

zh:
  # Pulled verbatim from archetype.i18n.zh at generation time.
  # Same section structure as en — parity validated.
