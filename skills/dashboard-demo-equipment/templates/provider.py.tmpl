TZ = timezone(timedelta(hours=8))


def _t_minutes() -> float:
    now = datetime.now(TZ)
    return now.hour * 60 + now.minute + now.second / 60


def _generate_instance_points(instance: dict[str, Any]) -> dict[str, dict[str, Any]]:
    """Run every point's generator against the current load envelope.

    Dispatch by point.generator.kind. New kinds added here MUST be documented
    in archetypes/_README.md under "Generator kinds" in the same commit.
    """
    state = get_demo_state()
    overrides = state.list_setpoint_overrides(instance["id"])
    running, _, _ = _operating_phase(instance, datetime.now(TZ))
    load = _load_envelope(instance, datetime.now(TZ))

    out: dict[str, dict[str, Any]] = {}
    now_iso = datetime.now(TZ).isoformat()
    for p in POINTS:
        suffix = p["suffix"]
        value = _dispatch_generator(p, instance, running, load, overrides, out)
        out[suffix] = {
            "pointId": instance["point_id_base"] + p["pid_offset"],
            "value": None if value is None else round(value, 2),
            "units": p["unit"],
            "dis": suffix,
            "quality": p.get("quality_default", "good"),
            "lastSeen": now_iso,
        }
    return out


